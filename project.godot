; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tidemarks"
config/description="A casual nautical trading game"
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0.05, 0.1, 0.2, 1)

[autoload]

GameState="*res://scripts/core/GameState.gd"
Economy="*res://scripts/core/Economy.gd"
VoyageManager="*res://scripts/core/VoyageManager.gd"
SaveLoad="*res://scripts/core/SaveLoad.gd"

[display]

window/size/viewport_width=390
window/size/viewport_height=844
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[rendering]

renderer/rendering_method="mobile"
